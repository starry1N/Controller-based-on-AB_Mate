{
  "name": "abmate-app",
  "version": "1.0.0",
  "description": "AB-Mate Bluetooth Earbuds Control App",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "vite build",
    "preview": "vite preview",
    "dev": "vite",
    "dev:android": "npm run build && npx cap sync android && npx cap run android",
    "build:android": "npm run build && npx cap sync android",
    "open:android": "npx cap open android",
    "sync:android": "npx cap sync android",
    "add:android": "npx cap add android",
    "android:clean": "cd android && ./gradlew clean && cd ..",
    "android:build": "cd android && ./gradlew assembleRelease && cd ..",
    "android:keystory": "keytool -genkey -v -keystore release.keystore -keyalg RSA -keysize 2048 -validity 10000 -alias ab_mate_key",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/device": "^6.0.0",
    "@capacitor/browser": "^6.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
