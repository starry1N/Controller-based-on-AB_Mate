{
  "name": "electron-react-app",
  "version": "1.0.0",
  "description": "Electron + React Application",
  "main": "dist/main/main.js",
  "homepage": "./",
  "private": true,
  "author": "Your Name",
  "license": "MIT",
  "scripts": {
    "dev": "npm run build-main && npm run dev:all",
    "dev:all": "concurrently \"npx vite\" \"npm run dev:electron\"",
    "dev:electron": "node -e \"setTimeout(() => require('child_process').exec('cross-env NODE_ENV=development electron .'), 5000)\"",
    "build-main": "esbuild src/main/main.ts src/main/preload.ts --bundle --platform=node --target=node18 --external:electron --outdir=dist/main --sourcemap",
    "build-renderer": "vite build",
    "build": "npm run build-main && npm run build-renderer && electron-builder",
    "preview": "vite preview",
    "start": "electron .",
    "dist": "npm run build"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "cross-env": "^10.1.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "esbuild": "^0.19.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "build": {
    "appId": "com.electron.app",
    "productName": "Electron React App",
    "files": [
      "dist/",
      "node_modules/",
      "package.json"
    ],
    "directories": {
      "buildResources": "public"
    }
  }
}
